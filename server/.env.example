# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000

# Niveau de log : debug | info | warn | error
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────
# Laisser vide en dev (autorise tout)
# En prod : mettre l'URL exacte du frontend Vercel
# CORS_ORIGIN=https://score26.vercel.app

# ── Base de données ───────────────────────────────────────────────────────────
# En dev : laisser vide (fichier local server/score26.db)
# En prod (Fly.io) : pointer sur le volume persistant
# DATABASE_PATH=/data/score26.db

# ── Admin ─────────────────────────────────────────────────────────────────────
# Token secret pour /admin — OBLIGATOIRE en prod, changer avant déploiement
ADMIN_TOKEN=change_this_before_deploy

# ── APIs football (optionnelles) ──────────────────────────────────────────────
# football-data.org — résultats finaux (gratuit, sans cap journalier)
# FOOTBALL_DATA_KEY=your_key_here

# api-football.com — scores live (gratuit, 100 req/jour)
# API_FOOTBALL_KEY=your_key_here

# ── Notifications push (VAPID) ────────────────────────────────────────────────
# Générer UNE SEULE FOIS avec : node generate-vapid.js
# Ne jamais regénérer en prod (invalide toutes les subscriptions existantes)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@score26.app
